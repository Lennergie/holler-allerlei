---
import Layout from "@/layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import CategoryIcons from "../components/CategoryIcons.astro";
import LocationMap from "../components/LocationMap.astro";
import FeatureBlock from "../components/FeatureBlock.astro"
import News from '../components/News.astro';
import FlyerComponent from "../components/FlyerComponent.astro";

const hero = {
    image: "/images/hero.webp",
    h1: "Entdecken statt Klicken!",
    h2: "Kreativ mit Herz & Hand:",
    p: "Handgemachtes, Schönes & Persönliches – direkt aus der Region."
}

const holzBlock = {
    layout: 'horizontal',
    content: {
        headline: 'Einzelstücke aus Holz',
        description:
            'Jedes Stück ist ein echtes Unikat: kein Produkt von der Stange, sondern mit Charakter, die aus Liebe zum Material gefertigt werden– direkt aus der eigenen Heimwerkstatt, mit Herz & Hand.',
        buttonText: 'Entdecken',
        buttonLink: '/selbstgemachtes#mgdesign',
    },
    images: [
        {
            url: '/images/micha.webp',
            alt: 'MG Design Logo',
        },
    ],
};



const linksBlock = {
    layout: 'links',
    content: {
        headline: 'Service vor Ort!',
        description: 'Neben unserem umfangreichen Sortiment bieten wir dir auch verschiedene Dienstleistungen an, die deinen Alltag erleichtern.',

    },
    images: [
        { url: '/images/paketshop.webp', alt: 'Paketshop', headline: 'Paketshop', text: 'Ausweis wenn eigenes Paket, Vollmacht von Paket Inhaber + eigener Ausweis' },
        { url: '/images/aenderungsschneiderei.webp', alt: 'Änderungsschneiderei', headline: 'Änderungsschneiderei', text: 'Was nicht passt wird \n' +
                'passend gemacht! ' },
        { url: '/images/schuhster.webp', alt: 'Schuster-Service', headline: 'Schuster-Service', text: 'Wir hauchen deinen kaputten Schuhen wieder Leben ein' },
        { url: '/images/reinigung.webp', alt: 'Reinigung', headline: 'Reinigung', text: 'Von Bettwäsche zu Tischdecken - das schaffen wir!' },
    ],
};

const feenBlock = {
    layout: 'horizontal',
    content: {
        headline: 'Feenzauber näht für Euch',
        description:
            'Wir sind für euch kreativ - mit viel Liebe zum Detail. \n' +
            'Ob Raysinarbeiten, Körnerkissen oder ganz andere Ideen: \n' +
            'Bei uns findet ihr eigene Kreationen und ein offenes Ohr für individuelle Wünsche.',
        buttonText: 'Entdecken',
        buttonLink: '/selbstgemachtes#feenzauber',
    },
    images: [
        {
            url: '/images/feenzauber.webp',
            alt: 'Feenzauber Holler Allerlei',
        },
    ],
};
---


<Layout title="Holler Allerlei" description="Dein Lieblingsladen in Holle: Handgemachtes, Kreativbedarf, Schulbedarf, Wolle, Dekoartikel und persönlicher Service seit 2009.">
    <Hero block={hero} />
    <FlyerComponent />
    <CategoryIcons />
    <News />
    <FeatureBlock block={holzBlock} />
    <FeatureBlock block={linksBlock} />
    <FeatureBlock block={feenBlock} />
    <LocationMap />
</Layout>
