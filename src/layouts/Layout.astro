---
import TheHeader from "../components/TheHeader.vue";
import "./../styles/global.css";
import ParticleBg from "@/components/ParticleBg.vue";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Holler Allerlei",
  description = "Dein Lieblingsladen in Holle: Handgemachtes, Kreativbedarf, Schulbedarf, Wolle und persönlicher Service seit 2009.",
  ogImage = "/Logo_black.webp",
} = Astro.props;

const pageTitle = title === "Holler Allerlei" ? title : `${title} | Holler Allerlei`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || "https://www.holler-allerlei.de");
---

<script>
  import { initSmoothScrolling } from "../scripts/smoothscroll";
  import { animateContents } from "../scripts/globalReveal";
  import gsap from "gsap";

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  initSmoothScrolling();

  const showLoader = !sessionStorage.getItem("loaderShown");

  if (showLoader) {
    sessionStorage.setItem("loaderShown", "true");
  }

  window.addEventListener("DOMContentLoaded", () => {
    animateContents();

    const loader = document.querySelector(".loading") as HTMLElement;
    if (!loader) return;

    if (showLoader && !prefersReducedMotion) {
      gsap.to(loader, {
        duration: 0.8,
        delay: 1,
        ease: "power3.inOut",
        opacity: 0,
        onComplete: () => {
          loader.style.display = "none";
        },
      });
    } else {
      loader.style.display = "none";
    }
  });
</script>

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="de_DE" />

    <!-- LocalBusiness Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Holler Allerlei",
      "description": "Lieblingsladen in Holle: Handgemachtes, Kreativbedarf, Schulbedarf, Wolle, Dekoartikel und persönlicher Service.",
      "url": "https://www.holler-allerlei.de",
      "telephone": "+4950621830",
      "email": "holler.allerlei@email.de",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Marktstraße 19",
        "addressLocality": "Holle",
        "postalCode": "31188",
        "addressCountry": "DE"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Thursday", "Friday"],
          "opens": "09:00",
          "closes": "12:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Thursday", "Friday"],
          "opens": "14:30",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Wednesday",
          "opens": "09:00",
          "closes": "12:30"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "13:00"
        }
      ],
      "sameAs": [
        "https://www.facebook.com/catringrassmueller/",
        "https://www.instagram.com/hollerallerlei/"
      ]
    })} />
  </head>
  <body>
    <ParticleBg client:only="vue" style="z-index: 0; position: fixed;"/>
    <TheHeader client:load />
    <div style="z-index: 1; position: relative;">
      <slot />
    </div>
    <Footer style="z-index: 1; position: relative;" />
    <div class="loading" aria-hidden="true">
      <img src="/Logo_black.webp" alt="" width="2094" height="532" class="w-[400px] max-w-3/4 h-auto" />
    </div>
  </body>
</html>

<style>
  .loading {
    width: 100%;
    height: 100vh;
    position: fixed;
    inset: 0;
    background: var(--mainBg);
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .loading img {
    opacity: 0;
    animation-name: fadeIn;
    animation-duration: 0.3s;
    animation-delay: 0.3s;
    animation-fill-mode: forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
